# Optional overrides (gitignored if you use .env.development.local or .env.local).
#
# Default dev URL is already set in .env.development (hosted Render).
#
# Use LOCAL backend + Vite proxy instead — create .env.development.local with:
#   VITE_USE_LOCAL_API=1
#
# Or set a different API (no /api suffix):
# VITE_API_BASE=https://remix-fnd.onrender.com
